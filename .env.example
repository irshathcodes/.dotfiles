# Dotfiles secrets template. Copy to `.env` and fill in real values:
#   cp .env.example .env && chmod 600 .env
# `.env` is gitignored. It is sourced by .zshrc so tools can read these vars.

# --- Atlassian (Jira + Confluence) ---
# Token: https://id.atlassian.com/manage-profile/security/api-tokens
export JIRA_URL="https://your-org.atlassian.net"
export JIRA_USERNAME="you@example.com"
export JIRA_API_TOKEN="replace-me"

export CONFLUENCE_URL="https://your-org.atlassian.net/wiki"
export CONFLUENCE_USERNAME="you@example.com"
export CONFLUENCE_API_TOKEN="replace-me"

# --- Telegram notifications (Claude Code hooks) ---
# Bot token from @BotFather; chat ID from getUpdates after messaging the bot.
# Must also exist in .env on any remote host running Claude Code (e.g. moideen).
export TELEGRAM_BOT_TOKEN="123456:replace-me"
export TELEGRAM_CHAT_ID="replace-me"
